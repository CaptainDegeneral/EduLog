# Backend
APP_NAME=EduLog API
DEBUG=true
API_V1_PREFIX=/api
HOST=127.0.0.1
PORT=8000
DATABASE_URL=sqlite+aiosqlite:///./backend/edulog.db
SQL_ECHO=false
AUTO_CREATE_TABLES=false
LOG_LEVEL=INFO

# Frontend
# Production example:
# VITE_API_BASE_URL=https://your-domain.com/api
VITE_API_BASE_URL=http://127.0.0.1:8000/api

# Reverse proxy ports on host (optional override)
HTTP_PORT=80
HTTPS_PORT=443
